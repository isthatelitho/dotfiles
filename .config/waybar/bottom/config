{
  "layer": "top",
  "position": "bottom",
  "spacing": 10,
  "height": 24,

  "modules-left": [
    "custom/window"
  ],

  "modules-center": [],

  "modules-right": [
    "tray",
    "custom/uptime",
    "battery",
    "power-profiles-daemon",
    "backlight"
  ],

  "custom/uptime": {
    "exec": "awk '{d=int($1/86400); h=int(($1%86400)/3600); m=int(($1%3600)/60); if (d>0) printf \"[up %dd %dh]\", d, h; else printf \"[up %dh %dm]\", h, m}' /proc/uptime",
    "interval": 60,
    "tooltip": false
  },

  "custom/window": {
    "exec": "~/.config/waybar/window.sh",
    "return-type": "json"
  },


  "custom/theme": {
    "format": "[theme = solitude]",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "[btr {capacity}%]",
    "tooltip-format": "{time} remaining"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nClick to cycle",
    "format-icons": {
      "default": "[pwr]",
      "performance": "[per]",
      "balanced": "[bal]",
      "power-saver": "[ps]"
    }
  },

  "backlight": {
    "format": "[bri {percent}%]",
    "tooltip": true
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
